/**
 * Environment Configuration Examples
 * Copy and update these to match your deployment environment
 */

// ============================================================================
// .env.example (Backend - Cloudflare Workers)
// ============================================================================

# Database
DATABASE_URL=https://api.cloudflare.com/client/v4/accounts/{account_id}/d1/database/{database_id}
AUTH_TOKEN=your_cloudflare_api_token

# R2 (Remote Storage)
R2_BUCKET_NAME=orland-media
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Environment
ENVIRONMENT=production
LOG_LEVEL=info
ENABLE_DEBUG=false

# CORS Origins
ALLOWED_ORIGINS=https://apptalent.yourdomain.com,https://appclient.yourdomain.com,https://appadmin.yourdomain.com

# API Keys
YOUTUBE_API_KEY=your_youtube_api_key
JWT_SECRET=your_jwt_secret

# Feature Flags
ENABLE_BULK_IMPORT=true
ENABLE_AGENCY_ROSTER=true
ENABLE_PREMIUM_FEATURES=true
MAX_BULK_ITEMS=100
MAX_VIDEOS_IMPORT=50

# ============================================================================
# .env.local (Frontend - React/Vite)
// ============================================================================

VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_API_PUBLIC_URL=https://api.yourdomain.com/api/v1
VITE_R2_UPLOAD_URL=https://api.yourdomain.com/api/v1/media/upload-url
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug

# Optional
VITE_AGENCY_ID=default_agency_id
VITE_SENTRY_DSN=your_sentry_dsn

# ============================================================================
# .env.test (Testing Environment)
// ============================================================================

DATABASE_URL=file:./test.db
R2_BUCKET_NAME=test-bucket
ENVIRONMENT=test
ENABLE_DEBUG=true
MAX_BULK_ITEMS=10
