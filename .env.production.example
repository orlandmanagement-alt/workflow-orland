# Enterprise SSO Configuration Template
# File: .env.production.example

# ========================================
# SSO SERVICE CONFIGURATION
# ========================================

# Database Binding (Cloudflare D1)
DB_SSO=sso_database

# Cryptography
HASH_PEPPER=your-global-pepper-string-must-be-32-chars-minimum
PBKDF2_ITER=100000
JWT_SECRET=your-jwt-secret-must-be-32-chars-minimum-for-security

# Session Configuration
SESSION_TTL=43200
JWT_EXPIRY=900
COOKIE_DOMAIN=.orlandmanagement.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax

# CAPTCHA Protection
TURNSTILE_SITE_KEY=0x4AAAAAACs8dTzAqMf1YwNJ
TURNSTILE_SECRET=your-cloudflare-turnstile-secret-key

# Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900
ACCOUNT_LOCKOUT_DURATION=1800
CLEANUP_INTERVAL=600000

# Portal URLs (for redirect after login)
TALENT_URL=https://talent.orlandmanagement.com
CLIENT_URL=https://client.orlandmanagement.com
ADMIN_URL=https://admin.orlandmanagement.com

# Email Service
RESEND_API_KEY=re_your_resend_api_key_here
MAILCHANNELS_MESSAGE_ID=your-mailchannels-id

# ========================================
# BUSINESS API CONFIGURATION
# ========================================

# SSO Integration
SSO_SERVICE_URL=https://www.orlandmanagement.com/api/auth
SSO_VALIDATE_ENDPOINT=/validate-session

# Caching
CACHE_TTL_SECONDS=300
CACHE_CLEANUP_INTERVAL=600000

# Redis (optional, for production)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Rate Limiting
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=60

# ========================================
# FRONTEND CONFIGURATION
# ========================================

REACT_APP_SSO_URL=https://www.orlandmanagement.com
REACT_APP_API_URL=https://api.orlandmanagement.com
REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAACs8dTzAqMf1YwNJ
REACT_APP_AUTH_CACHE_TTL=3600000

# ========================================
# SECURITY & COMPLIANCE
# ========================================

# Enable strict security headers
ENABLE_SECURITY_HEADERS=true
ENABLE_CSP=true
CSP_REPORT_URI=https://api.orlandmanagement.com/security/csp-report

# Session hijacking detection
ENABLE_IP_VALIDATION=true
IP_VALIDATION_MODE=moderate
ENABLE_USER_AGENT_VALIDATION=true

# Audit logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_TABLE=audit_logs

# ========================================
# MONITORING & DEBUGGING
# ========================================

LOG_LEVEL=info
DEBUG_MODE=false
ENABLE_PERFORMANCE_METRICS=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
