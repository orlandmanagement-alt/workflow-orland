# =========================================
# 1. DEPENDENCIES & PACKAGES
# =========================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
# (Catatan: bun.lockb tidak di-ignore karena Anda menggunakan Bun, lockfile ini penting untuk dicommit)

# =========================================
# 2. ENVIRONMENT VARIABLES (SANGAT KRITIS)
# Mencegah kebocoran API Key dan Secret
# =========================================
.env
.env.*
!.env.example
!.env.template

# =========================================
# 3. CLOUDFLARE WORKERS & WRANGLER
# Mencegah file cache lokal Cloudflare masuk ke GitHub
# =========================================
.wrangler/
dist/
build/
.dev.vars

# =========================================
# 4. FRAMEWORKS & MONOREPO (Sesuai aslinya)
# =========================================
.turbo/
.next/
out/
.output/

# =========================================
# 5. LOGS & DEBUGGING
# File sampah hasil error atau log terminal
# =========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-error.log*

# =========================================
# 6. OS & IDE (Editor Sampah)
# File sampah bawaan Mac/Windows dan VSCode
# =========================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =========================================
# 7. TESTING & COVERAGE
# =========================================
coverage/
.nyc_output/